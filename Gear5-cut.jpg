      "Watermark trích xuất: Nhat Truong - Duc Phatÿ\n"
     ]
    }
   ],
   "source": [
    "# Tạo bản sao ảnh để thử nghiệm\n",
    "test_image = original_image.copy()\n",
    "\n",
    "# Chèn watermark\n",
    "watermark_text = \"Nhat Truong - Duc Phat\"\n",
    "watermarked_image = embed_lsb(test_image, watermark_text)\n",
    "\n",
    "# Hiển thị ảnh đã nhúng\n",
    "show_image(watermarked_image, title=\"Ảnh đã nhúng LSB\")\n",
    "\n",
    "# Giải mã watermark\n",
    "extracted_text = extract_lsb(watermarked_image)\n",
    "print(\"Watermark trích xuất:\", extracted_text)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 40,
   "id": "d5ae4ede-2709-4062-8a28-148af9b1d1d6",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "def psnr_manual(img1, img2):\n",
    "    mse = np.mean((img1.astype(\"float\") - img2.astype(\"float\")) ** 2)\n",
    "    if mse == 0:\n",
    "        return float('inf')\n",
    "    PIXEL_MAX = 255.0\n",
    "    return 20 * np.log10(PIXEL_MAX / np.sqrt(mse))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "d18c3f63-5941-4f37-b6b2-dc217f6ff850",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "PSNR giữa ảnh gốc và ảnh LSB: 100.20 dB\n"
     ]
    }
   ],
   "source": [
    "psnr_value = psnr_manual(original_image, watermarked_image)\n",
    "print(f\"PSNR giữa ảnh gốc và ảnh LSB: {psnr_value:.2f} dB\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "id": "24081201-a2af-4a17-ad7b-cb84c1c6ab19",
   "metadata": {},
   "outputs": [],
   "source": [
    "#DWT"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "id": "fd18c689-f62d-48ad-ae53-5fdbc439209f",
   "metadata": {},
   "outputs": [],
   "source": [
    "def embed_dwt(image, watermark_text):\n",
    "    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "    # DWT\n",
    "    coeffs2 = pywt.dwt2(gray, 'haar')\n",
    "    LL, (LH, HL, HH) = coeffs2\n",
    "\n",
    "    # Chuyển watermark sang nhị phân\n",
    "    watermark_bin = ''.join(format(ord(char), '08b') for char in watermark_text)\n",
    "    watermark_bin += '1111111111111110'\n",
    "\n",
    "    flat_hl = HL.flatten()\n",
    "    \n",
    "    # Ép kiểu về int để dùng bitwise\n",
    "    flat_hl_int = flat_hl.astype(np.int32)\n",
    "\n",
    "    for i in range(len(watermark_bin)):\n",
    "        if i < len(flat_hl_int):\n",
    "            flat_hl_int[i] = (flat_hl_int[i] & ~1) | int(watermark_bin[i])\n",
    "\n",
    "    # Trả HL về lại float để tránh lỗi khi IDWT\n",
    "    HL_modified = flat_hl_int.astype(np.float32).reshape(HL.shape)\n",
    "\n",
    "    # Tái cấu trúc ảnh\n",
    "    coeffs_modified = (LL, (LH, HL_modified, HH))\n",
    "    watermarked = pywt.idwt2(coeffs_modified, 'haar')\n",
    "    watermarked = np.clip(watermarked, 0, 255).astype(np.uint8)\n",
    "    \n",
    "    return cv2.merge([watermarked]*3)  # Trả về ảnh RGB 3 kênh\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 44,
   "id": "ba274d43-40c2-4c61-a294-95d428ec2d54",
   "metadata": {},
   "outputs": [],
   "source": [
    "def extract_dwt(watermarked_image):\n",
    "    # Chuyển về ảnh xám\n",
    "    gray = cv2.cvtColor(watermarked_image, cv2.COLOR_BGR2GRAY)\n",
    "    \n",
    "    # DWT\n",
    "    coeffs2 = pywt.dwt2(gray, 'haar')\n",
    "    _, (_, HL, _, _) = coeffs2\n",
    "    \n",
    "    flat_hl = HL.flatten()\n",
    "    bits = [str(int(val) & 1) for val in flat_hl]\n",
    "    \n",
    "    # Chuyển từng nhóm 8 bits thành ký tự\n",
    "    chars = []\n",
    "    for i in range(0, len(bits), 8):\n",
    "        byte = bits[i:i+8]\n",
    "        if len(byte) < 8:\n",
    "            break\n",
    "        char = chr(int(''.join(byte), 2))\n",
    "        chars.append(char)\n",
    "        if ''.join(byte) == '11111110':\n",
    "            break\n",
    "    return ''.join(chars[:-1])\n"
   ]
  },
