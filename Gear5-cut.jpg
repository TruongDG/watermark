    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import pywt\n",
    "import ipywidgets as widgets\n",
    "from IPython.display import display"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 34,
   "id": "dbb0951d-63b7-4773-a352-17940ecab243",
   "metadata": {},
   "outputs": [],
   "source": [
    "def show_image(image, title=\"Ảnh\", size=(6, 6)):\n",
    "    plt.figure(figsize=size)\n",
    "    if len(image.shape) == 2:  # grayscale\n",
    "        plt.imshow(image, cmap='gray')\n",
    "    else:\n",
    "        plt.imshow(cv2.cvtColor(image, cv2.COLOR_BGR2RGB))\n",
    "    plt.title(title)\n",
    "    plt.axis('off')\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "d3bccf25-1134-4c7b-bf25-9cdbafff6f1d",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 600x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Load ảnh gốc\n",
    "image_path = 'Gear5-cut.jpg'\n",
    "original_image = cv2.imread(image_path)\n",
    "\n",
    "# Hiển thị\n",
    "show_image(original_image, title=\"Ảnh gốc\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "90d0de54-526d-4925-9888-e8c501f650e4",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 600x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "def convert_to_grayscale(image):\n",
    "    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\n",
    "    return gray\n",
    "\n",
    "gray_image = convert_to_grayscale(original_image)\n",
    "show_image(gray_image, title=\"Ảnh Grayscale\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 37,
   "id": "9148dab4-c44c-4213-a526-a6aef500d77e",
   "metadata": {},
   "outputs": [],
   "source": [
    "def embed_lsb(image, watermark_text):\n",
    "    image = image.copy()\n",
    "    # Chuyển watermark thành chuỗi nhị phân\n",
    "    watermark_bin = ''.join([format(ord(char), '08b') for char in watermark_text])\n",
    "    watermark_bin += '1111111111111110'  # Ký hiệu kết thúc\n",
    "\n",
    "    flat_image = image.flatten()\n",
    "    data_index = 0\n",
    "\n",
    "    for i in range(len(flat_image)):\n",
    "        if data_index < len(watermark_bin):\n",
    "            flat_image[i] = (flat_image[i] & ~1) | int(watermark_bin[data_index])\n",
    "            data_index += 1\n",
    "\n",
    "    watermarked_image = flat_image.reshape(image.shape)\n",
    "    return watermarked_image"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 38,
   "id": "e79d82a8-16e0-4cc6-b34b-39235ce6678c",
   "metadata": {},
   "outputs": [],
   "source": [
    "def extract_lsb(image):\n",
    "    flat_image = image.flatten()\n",
    "    bits = [str(pixel & 1) for pixel in flat_image]\n",
    "    \n",
    "    chars = []\n",
    "    for i in range(0, len(bits), 8):\n",
    "        byte = bits[i:i+8]\n",
    "        if len(byte) < 8:\n",
    "            break\n",
    "        char = chr(int(''.join(byte), 2))\n",
    "        chars.append(char)\n",
    "        if ''.join(byte) == '11111110':  # dấu kết thúc\n",
    "            break\n",
    "    return ''.join(chars[:-1])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 39,
   "id": "033787ba-7f97-4cca-883c-80f3d263413c",
   "metadata": {},
   "outputs": [
